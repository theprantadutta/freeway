# Admin API key for accessing Freeway control panel endpoints
ADMIN_API_KEY=your-admin-api-key

# OpenRouter API key (required for chat completions)
OPENROUTER_API_KEY=your-openrouter-api-key

# Database Configuration
# Option 1: Full connection string
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/freeway

# Option 2: Individual parameters
DB_HOST=localhost
DB_PORT=5432
DB_USER=freeway
DB_PASSWORD=your-db-password
DB_NAME=freeway

# Optional
REQUEST_TIMEOUT_SECONDS=30
COMPLETION_TIMEOUT_SECONDS=120
