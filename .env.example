# Required - API key for accessing Freeway endpoints
API_KEY=your-freeway-api-key

# Required only if health checks are enabled
OPENROUTER_API_KEY=your-openrouter-api-key

# Health Check Settings
HEALTH_CHECK_ENABLED=true  # Set to false to disable (just serve model list)
HEALTH_CHECK_HOUR=0  # Hour to run daily health check (0-23, UTC, default midnight)
CHECK_DELAY_SECONDS=60.0  # Delay between each model check (60s for free models)

# Optional
HISTORY_SIZE=20
REQUEST_TIMEOUT_SECONDS=30
