# Required only if health checks are enabled
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# Health Check Settings
HEALTH_CHECK_ENABLED=true  # Set to false to disable (just serve model list)
CHECK_INTERVAL_SECONDS=86400  # 24 hours (once per day)
CHECK_DELAY_SECONDS=30.0  # Delay between each model check

# Optional
HISTORY_SIZE=20
REQUEST_TIMEOUT_SECONDS=30
